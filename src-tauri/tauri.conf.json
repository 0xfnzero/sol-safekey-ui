{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sol SafeKey",
  "version": "0.1.0",
  "identifier": "dev.fnzero.sol-safekey-ui",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3840/en/",
    "beforeDevCommand": "npm run dev:stack",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Sol SafeKey",
        "width": 1100,
        "height": 760,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
